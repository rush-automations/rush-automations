{
 "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
 "vcs": {
 "enabled": true,
 "clientKind": "git",
 "useIgnoreFile": true
 },
 "files": {
 "ignoreUnknown": true,
 "ignore": ["dist/**", "node_modules/**", "*.min.js"]
 },
 "formatter": {
 "enabled": true,
 "formatWithErrors": false,
 "indentStyle": "space",
 "indentWidth": 2,
 "lineEnding": "lf",
 "lineWidth": 100
 },
 "organizeImports": {
 "enabled": true
 },
 "linter": {
 "enabled": true,
 "rules": {
 "recommended": true,
 "suspicious": {
 "noExplicitAny": "warn",
 "noArrayIndexKey": "warn"
 },
 "style": {
 "noNonNullAssertion": "warn",
 "useConsistentArrayType": "error",
 "useConsistentBuiltinsOverTypeAssertion": "error",
 "useShorthandArrayType": "error"
 },
 "complexity": {
 "noForEach": "off",
 "noStaticOnlyClass": "error",
 "useSimplifiedLogicExpression": "warn"
 },
 "correctness": {
 "noUnusedVariables": "error",
 "noUnusedImports": "error",
 "useExhaustiveDependencies": "warn"
 },
 "performance": {
 "noBarrelFile": "warn"
 }
 }
 },
 "javascript": {
 "formatter": {
 "quoteStyle": "single",
 "jsxQuoteStyle": "double",
 "trailingCommas": "es5",
 "semicolons": "always",
 "arrowParentheses": "always"
 }
 }
}
